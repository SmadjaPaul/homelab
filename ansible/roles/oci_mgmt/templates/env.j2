# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN={{ cloudflare_tunnel_token }}

# PostgreSQL
POSTGRES_USER=homelab
POSTGRES_PASSWORD={{ postgres_password }}
POSTGRES_DB=homelab

# Authentik
AUTHENTIK_SECRET_KEY={{ authentik_secret_key }}
AUTHENTIK_PUBLIC_URL={{ authentik_public_url | default('https://auth.smadja.dev') }}
# Token from Authentik UI: Outposts → default-outpost (or create) → copy token. Leave empty until outpost is configured.
AUTHENTIK_OUTPOST_TOKEN={{ authentik_outpost_token | default('') }}

# Authentik SMTP (for password recovery emails)
# Configure SMTP settings for password reset emails
# Example for Gmail: smtp.gmail.com:587 with App Password
# Example for ProtonMail: mail.protonmail.com:587
AUTHENTIK_EMAIL__HOST={{ authentik_smtp_host | default('') }}
AUTHENTIK_EMAIL__PORT={{ authentik_smtp_port | default('587') }}
AUTHENTIK_EMAIL__USERNAME={{ authentik_smtp_username | default('') }}
AUTHENTIK_EMAIL__PASSWORD={{ authentik_smtp_password | default('') }}
AUTHENTIK_EMAIL__USE_TLS={{ authentik_smtp_use_tls | default('true') }}
AUTHENTIK_EMAIL__FROM={{ authentik_smtp_from | default('noreply@smadja.dev') }}

# Omni
OMNI_ACCOUNT_ID=homelab
OMNI_NAME=Homelab Omni

# LiteLLM (optional: for admin API and Terraform; leave empty to run without)
LITELLM_MASTER_KEY={{ litellm_master_key | default('') }}
LITELLM_SALT_KEY={{ litellm_salt_key | default('') }}

# OpenClaw — gateway token for CLI/apps (see SECURITY-OPENCLAW.md). Generate: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN={{ openclaw_gateway_token | default('') }}
