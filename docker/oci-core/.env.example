# OCI Core Services Environment Variables
# Copy this file to .env and fill in your values
# Then deploy with: doppler run --project infrastructure --config prd -- docker compose --profile core up -d

# ============================================================================
# ACME / SSL
# ============================================================================
ACME_EMAIL=admin@smadja.dev

# ============================================================================
# CLOUDFLARE TUNNEL
# Get this from Cloudflare Zero Trust dashboard
# ============================================================================
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here

# ============================================================================
# AUTHENTIK
# Generate with: openssl rand -base64 60
# ============================================================================
AUTHENTIK_SECRET_KEY=your-secret-key-here-min-50-chars
AUTHENTIK_POSTGRES_PASSWORD=your-secure-password-here

# ============================================================================
# SMTP (Optional - for Authentik password reset)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@smadja.dev

# ============================================================================
# TWINGATE
# Get these from Twingate admin console
# ============================================================================
TWINGATE_NETWORK=smadja
TWINGATE_ACCESS_TOKEN=your-access-token
TWINGATE_REFRESH_TOKEN=your-refresh-token

# ============================================================================
# GRAFANA CLOUD
# Get these from Grafana Cloud portal
# ============================================================================
GRAFANA_CLOUD_URL=https://prometheus-prod-...grafana.net
GRAFANA_CLOUD_USER=your-stack-user
GRAFANA_CLOUD_API_KEY=your-api-key

# ============================================================================
# GOTIFY
# ============================================================================
GOTIFY_DEFAULTUSER_NAME=admin
GOTIFY_DEFAULTUSER_PASS=your-secure-password

# ============================================================================
# VAULTWARDEN
# Generate with: openssl rand -base64 48
# ============================================================================
VAULTWARDEN_ADMIN_TOKEN=your-admin-token-here

# ============================================================================
# OPTIONAL: For local testing without Doppler
# Uncomment and fill these if not using Doppler CLI
# ============================================================================
# DOPPLER_TOKEN=dp.st.xxxxxx
