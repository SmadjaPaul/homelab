# Copy to terraform.tfvars and fill (do not commit terraform.tfvars if it contains secrets)
# Prefer environment variables: AUTHENTIK_URL, AUTHENTIK_TOKEN

# authentik_url   = "https://authentik.apps.example.com/"
# authentik_token = "your-api-token"

# OCI Vault integration (optional - if not set, use_global_settings=true)
# Get compartment_id from terraform/oracle-cloud outputs:
#   cd ../oracle-cloud && terraform output -raw compartment_id
# oci_compartment_id = "ocid1.compartment.oc1..xxxxx"

# Custom secret names (optional - defaults match terraform/oracle-cloud/vault-secrets.tf)
# oci_smtp_secret_names = {
#   host     = "homelab-authentik-smtp-host"
#   port     = "homelab-authentik-smtp-port"
#   username = "homelab-authentik-smtp-username"
#   password = "homelab-authentik-smtp-password"
#   from     = "homelab-authentik-smtp-from"
# }
