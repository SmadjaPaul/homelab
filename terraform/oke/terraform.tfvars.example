# OKE Terraform Variables
# Copy this file to terraform.tfvars and fill in your values

# Required
region         = "eu-paris-1"
tenancy_ocid   = "ocid1.tenancy.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
compartment_id = "ocid1.compartment.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Optional (defaults shown)
kubernetes_version = "v1.30.1"
environment        = "homelab"

# SSH key for debugging worker nodes (optional)
# ssh_public_key = "ssh-rsa AAAA..."
