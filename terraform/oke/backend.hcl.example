# Terraform Backend Configuration for OCI Object Storage
#
# ALL SECRETS are fetched from Doppler project "infrastructure"
#
# Setup locally:
#   1. Ensure Doppler CLI is installed and configured
#   2. Run: doppler setup --project infrastructure --config prd
#   3. Generate backend config: doppler run -- ./scripts/generate-backend.sh
#   4. Run: terraform init -backend-config=backend.hcl
#
# GitHub Actions automatically creates this file from Doppler secrets

bucket   = "terraform-states"
key      = "oke/terraform.tfstate"
region   = "eu-paris-1"
endpoint = "https://YOUR_NAMESPACE.compat.objectstorage.eu-paris-1.oraclecloud.com"

skip_region_validation      = true
skip_credentials_validation = true
skip_metadata_api_check     = true
force_path_style            = true
