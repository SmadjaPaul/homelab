# OCI Core Services Environment Variables - Phase 1
# Enterprise Homelab without Authentik
# Copy this file to .env and fill in your values from Doppler

# ============================================================================
# ACME / SSL
# ============================================================================
ACME_EMAIL=admin@smadja.dev

# ============================================================================
# CLOUDFLARE TUNNEL
# Get this from Cloudflare Zero Trust dashboard
# ============================================================================
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here

# ============================================================================
# GRAFANA CLOUD (Optional - for external monitoring)
# Get these from Grafana Cloud portal
# ============================================================================
GRAFANA_CLOUD_METRICS_URL=https://prometheus-prod-13-prod-us-east-0.grafana.net/api/prom/push
GRAFANA_CLOUD_LOGS_URL=https://logs-prod-012.grafana.net/loki/api/v1/push
GRAFANA_CLOUD_API_KEY=your-api-key
GRAFANA_CLOUD_USER=your-stack-user

# ============================================================================
# LITELLM
# Generate with: openssl rand -base64 32
# ============================================================================
LITELLM_MASTER_KEY=your-litellm-master-key
LITELLM_DATABASE_URL=sqlite:///app/litellm.db

# ============================================================================
# OPENCLAW
# Generate JWT secret with: openssl rand -base64 32
# ============================================================================
OPENCLAW_LITELLM_URL=http://litellm:4000
OPENCLAW_LITELLM_KEY=your-litellm-api-key
OPENCLAW_JWT_SECRET=your-jwt-secret

# ============================================================================
# OPTIONAL: For local testing without Doppler
# Uncomment and fill these if not using Doppler CLI
# ============================================================================
# DOPPLER_TOKEN=dp.st.xxxxxx
